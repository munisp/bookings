# OpenDesk .env.example — copy to .env and adjust. Every value below is a
# DEV-ONLY default that matches docker-compose.yml's ${VAR:-default}
# fallbacks, so the stack boots without a .env at all. In production these
# come from SOPS/Vault instead — see docs/runbooks/secrets.md.

# ---------------------------------------------------------------------------
# Postgres (superuser — infra only, apps should use per-service roles below)
# ---------------------------------------------------------------------------
POSTGRES_USER=opendesk
POSTGRES_PASSWORD=opendesk

# Per-service DB roles (SPEC-W3 §2, infra/postgres/init-scripts/05-app-roles.sql).
# The NOLOGIN group roles are app_booking / app_conversation / app_knowledge;
# services connect with the LOGIN variants below. Defaults keep the shared
# opendesk superuser for dev parity — set these to enforce RLS end-to-end.
BOOKING_PG_USER=app_booking_login
BOOKING_PG_PASS=app_booking_dev_password
#CONVERSATION_PG_USER=app_conversation_login
#CONVERSATION_PG_PASS=app_conversation_dev_password
#KNOWLEDGE_PG_USER=app_knowledge_login
#KNOWLEDGE_PG_PASS=app_knowledge_dev_password

# ---------------------------------------------------------------------------
# Keycloak (identity)
# ---------------------------------------------------------------------------
# Client secret of the `service-accounts` client (realm opendesk).
KEYCLOAK_ADMIN_CLIENT_SECRET=opendesk-service-secret

# ---------------------------------------------------------------------------
# LiveKit (voice)
# ---------------------------------------------------------------------------
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ---------------------------------------------------------------------------
# LLM (voice runtime + any LLM-judge/NER features; Ollama works out of box)
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=qwen3:8b
# Only needed for hosted providers (e.g. MiniMax): LLM_BASE_URL=https://api.minimax.io/v1
#LLM_API_KEY=

# ---------------------------------------------------------------------------
# Admin web (NextAuth)
# ---------------------------------------------------------------------------
AUTH_SECRET=dev-secret-change-me

# ---------------------------------------------------------------------------
# Twenty CRM (crm-sync)
# ---------------------------------------------------------------------------
TWENTY_API_KEY=opendesk-dev-twenty-api-key
TWENTY_WEBHOOK_SECRET=opendesk-dev-twenty-webhook-secret
TWENTY_ACCESS_TOKEN_SECRET=opendesk-twenty-access-token-dev
TWENTY_LOGIN_TOKEN_SECRET=opendesk-twenty-login-token-dev
TWENTY_REFRESH_TOKEN_SECRET=opendesk-twenty-refresh-token-dev
TWENTY_FILE_TOKEN_SECRET=opendesk-twenty-file-token-dev
TWENTY_APP_SECRET=opendesk-twenty-app-secret-dev

# ---------------------------------------------------------------------------
# MinIO (lakehouse + GDPR export bundles)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---------------------------------------------------------------------------
# Dapr component secrets (dev env-var secret store)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=
SMTP_PASSWORD=
TWILIO_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Gateway static secrets (NOT env-driven in dev — edit infra/apisix/apisix.yaml):
#   - jwt-auth HS256 consumer secret (opendesk-dev-jwt-hs256-secret-change-in-prod)
#   - openid-connect session secret (opendesk-dev-session-secret-0123456789abcdef)
# Both must be rotated for any non-local deployment (docs/runbooks/secrets.md).
# ---------------------------------------------------------------------------

# Misc non-secret toggles with compose fallbacks:
#AGENT_BACKEND=livekit
#LEDGER_IMPL=sim
