# ndpa-profile.env — Nigeria Data Protection Act 2023 compliance profile.
#
# Append this file to your .env (or source it before `docker compose up`) to
# run OpenDesk under the NDPA profile. Every variable has a matching
# ${VAR:-default} passthrough in docker-compose.yml. Full control mapping:
# docs/compliance/ndpa.md. Pair with the nigeria-sme industry pack
# (industries/nigeria-sme.yaml) for Pidgin-first tenants.
#
# NOTE: records-of-processing obligations + the data-residency guidance
# below assume a SELF-HOSTED deployment (docker-compose on-premises or the
# k3s appliance in deploy/k3s) with storage physically in Nigeria — see
# "Storage / residency" at the bottom.

# ---------------------------------------------------------------------------
# Retention (NDPA storage-limitation principle — personal data kept no
# longer than necessary). conversation-service hard-deletes turns older than
# this, hourly, per tenant. Platform default is 365; NDPA profile: 180 days.
# ---------------------------------------------------------------------------
RETENTION_ENABLED=true
RETENTION_DAYS=180
# RETENTION_SWEEP_SECONDS=3600   # default hourly; uncomment to tune
# RETENTION_BATCH_SIZE=1000      # default; uncomment to tune

# ---------------------------------------------------------------------------
# Biometrics OFF. Voiceprints are biometric data and qualify as sensitive
# personal data under NDPA 2023 (stricter consent + DPIA obligations). The
# NDPA profile disables speaker-identification voiceprints entirely.
# ---------------------------------------------------------------------------
VOICEPRINTS=off

# ---------------------------------------------------------------------------
# LLM call-intelligence OFF. INTEL_LLM=on would send transcript text to an
# LLM endpoint for NER/entity extraction — an extra processor in the data
# flow that needs its own records-of-processing entry + possibly cross-border
# transfer assessment. Keep it off for NDPA tenants (lexicon-only sentiment
# stays local and still runs).
# ---------------------------------------------------------------------------
INTEL_LLM=off

# ---------------------------------------------------------------------------
# Storage / residency (NOT env-driven — operator checklist):
#   * Self-host the whole stack in-country: docker-compose on a Nigerian
#     host, or the k3s appliance (deploy/k3s) on-prem at the business site.
#     Postgres, OpenSearch, MinIO (GDPR export bundles) and Kafka/Fluvio all
#     keep personal data on volumes local to that host.
#   * If a cloud VM is used, pin it to a Nigerian/African region (e.g.
#     Azure Johannesburg, AWS Cape Town) and record the transfer basis in
#     your records-of-processing entrys — cross-border transfer needs an adequacy
#     basis or explicit consent (NDPA ss. 41-43).
#   * LLM/STT/TTS must be local (Ollama qwen3:8b, faster-whisper, Piper) —
#     the dev defaults already are; do not point LLM_BASE_URL at a hosted
#     provider for NDPA tenants without a transfer assessment.
#   * Backups (infra/backups) inherit the residency of their target — keep
#     backup storage in the same jurisdiction.
# ---------------------------------------------------------------------------
