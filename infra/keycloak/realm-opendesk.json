{
  "realm": "opendesk",
  "enabled": true,
  "displayName": "OpenDesk",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "owner", "description": "Tenant owner — full control including billing and deletion" },
      { "name": "admin", "description": "Tenant admin — manage catalog, bookings, site" },
      { "name": "staff", "description": "Tenant staff — manage bookings" },
      { "name": "viewer", "description": "Read-only dashboard access" }
    ]
  },
  "groups": [
    {
      "name": "tenants",
      "path": "/tenants",
      "subGroups": [
        {
          "name": "acme",
          "path": "/tenants/acme",
          "attributes": {
            "tenant_slug": ["acme"]
          },
          "realmRoles": [],
          "subGroups": []
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "admin-web",
      "name": "OpenDesk Admin Web",
      "description": "Next.js admin dashboard (browser, Authorization Code + PKCE)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3001/*",
        "http://localhost:9080/*"
      ],
      "webOrigins": [
        "http://localhost:3001",
        "http://localhost:9080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3001/*##http://localhost:9080/*"
      },
      "protocolMappers": [
        {
          "name": "tenant_slugs",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_slugs",
            "full.path": "true",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "service-accounts",
      "name": "OpenDesk Service Accounts",
      "description": "Confidential client for service-to-service (client credentials)",
      "enabled": true,
      "publicClient": false,
      "secret": "opendesk-service-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [],
      "webOrigins": [],
      "protocolMappers": [
        {
          "name": "tenant_slugs",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_slugs",
            "full.path": "true",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@opendesk.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["owner"],
      "groups": ["/tenants/acme"]
    }
  ]
}
