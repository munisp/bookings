# ---- Auth.js / Keycloak OIDC ----
# Secret used to encrypt the Auth.js session cookie. Generate: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-me
# Public URL of this app (required by Auth.js v5 behind proxies)
AUTH_URL=http://localhost:3001
# Trust the host header (needed in Docker / behind APISIX)
AUTH_TRUST_HOST=true

# Keycloak realm issuer as reachable from the admin-web server (container-to-container).
KEYCLOAK_ISSUER=http://keycloak:8080/realms/opendesk
# Optional: browser-reachable issuer for the authorization redirect when it differs
# from the server-side issuer (e.g. http://localhost:8080/realms/opendesk in dev).
KEYCLOAK_ISSUER_PUBLIC=http://localhost:8080/realms/opendesk
KEYCLOAK_CLIENT_ID=admin-web

# ---- API gateway (APISIX) ----
# Server-side base URL for the BFF proxy (inside docker network use http://apisix:9080).
API_BASE_URL=http://localhost:9080
# Public base URL advertised to the browser.
NEXT_PUBLIC_API_BASE=http://localhost:9080
# WebSocket base for live booking events (gateway-edge via APISIX).
# May or may not include the trailing /ws path; the client normalises it.
NEXT_PUBLIC_WS_BASE=ws://localhost:9080/ws
